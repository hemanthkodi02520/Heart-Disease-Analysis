      <aliases enabled='yes' />
      <column caption='Age Category' datatype='string' name='[AgeCategory]' role='dimension' type='nominal' />
      <column caption='Alcohol Drinking' datatype='string' name='[AlcoholDrinking]' role='dimension' type='nominal' />
      <column caption='BMI Category' datatype='string' name='[Calculation_2025323157352448]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [BMI] &lt; 18.5 THEN &quot;Underweight&quot;&#13;&#10;ELSEIF [BMI] &lt; 25 THEN &quot;Normal&quot;&#13;&#10;ELSEIF [BMI] &lt; 30 THEN &quot;Overweight&quot;&#13;&#10;ELSE &quot;Obese&quot;&#13;&#10;END' />
      </column>
      <column caption='Senior Citizen' datatype='string' name='[Calculation_2025323157663745]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [AgeCategory] IN (&quot;65-69&quot;,&quot;70-74&quot;,&quot;75-79&quot;,&quot;80 or older&quot;)&#13;&#10;THEN &quot;Senior&quot;&#13;&#10;ELSE &quot;Adult&quot;&#13;&#10;END' />
      </column>
      <column caption='Risk Group' datatype='string' name='[Calculation_2025323157733378]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [HeartDisease] = &quot;Yes&quot; THEN&#13;&#10;&quot;High Risk&quot;&#13;&#10;ELSE&#13;&#10;&quot;Low Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='Smoker Status' datatype='string' name='[Calculation_2025323157790723]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Smoking] = &quot;Yes&quot; THEN&#13;&#10;&quot;Smoker&quot;&#13;&#10;ELSE&#13;&#10;&quot;Non-Smoker&quot;&#13;&#10;END' />
      </column>
